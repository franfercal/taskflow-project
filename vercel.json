{
  "version": 2,
  "builds": [
    {
      "src": "server/src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "server/src/index.js"
    },
    {
      "src": "/api-docs(.*)",
      "dest": "server/src/index.js"
    },
    {
      "src": "/openapi\\.(yaml|json)",
      "dest": "server/src/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
